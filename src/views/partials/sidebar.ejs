<%
  const path = currentPath || '/';

  const isDashboard = path === '/';
  const isUsers = path.startsWith('/users');
  const isSmartcardSection = path.startsWith('/smartcard'); // parent
  const isSmartcardRead = path === '/smartcard' || path.startsWith('/smartcard/read');
  const isSmartcardLogs = path.startsWith('/smartcard/logs');
  const isDocs = path.startsWith('/docs');
%>

<div id="sidebar-wrapper" class="d-flex flex-column">
  <div class="sidebar-heading">
    <div class="brand-badge">
      <i class="bi bi-grid-1x2"></i>
    </div>
    <div>
      <div>Admin Panel</div>
      <small class="text-white-50">Smart Service Console</small>
    </div>
  </div>

  <div class="list-group list-group-flush flex-grow-1">

    <!-- Dashboard -->
    <a href="/" class="list-group-item list-group-item-action <%= isDashboard ? 'active' : '' %>">
      <i class="bi bi-speedometer2"></i>
      <span>Dashboard</span>
    </a>

    <!-- Users -->
    <a href="/users" class="list-group-item list-group-item-action <%= isUsers ? 'active' : '' %>">
      <i class="bi bi-people"></i>
      <span>ผู้ใช้งาน</span>
    </a>

    <!-- Smartcard section with submenu -->
    <div class="list-group-item list-group-item-action sidebar-parent <%= isSmartcardSection ? 'active-parent' : '' %>">
      <div class="d-flex align-items-center justify-content-between sidebar-parent-toggle" data-bs-toggle="collapse" data-bs-target="#smartcardSubmenu" aria-expanded="<%= isSmartcardSection ? 'true' : 'false' %>">
        <div class="d-flex align-items-center gap-2">
          <i class="bi bi-credit-card-2-front"></i>
          <span>ระบบบัตรประชาชน</span>
        </div>
        <i class="bi bi-chevron-right small sidebar-parent-arrow <%= isSmartcardSection ? 'rotate' : '' %>"></i>
      </div>
      <div id="smartcardSubmenu" class="collapse sidebar-submenu <%= isSmartcardSection ? 'show' : '' %>">
        <a href="/smartcard" class="sidebar-subitem <%= isSmartcardRead ? 'active-sub' : '' %>">
          <span>อ่านบัตร</span>
        </a>
        <a href="/smartcard/logs" class="sidebar-subitem <%= isSmartcardLogs ? 'active-sub' : '' %>">
          <span>ประวัติการใช้งาน</span>
        </a>
      </div>
    </div>

    <!-- Docs -->
    <a href="/docs" target="_blank" class="list-group-item list-group-item-action <%= isDocs ? 'active' : '' %>">
      <i class="bi bi-braces-asterisk"></i>
      <span>API</span>
    </a>
  </div>

  <div class="footer-meta">
    <span>© <%= new Date().getFullYear() %> Admin</span>
    <small>Digital Identity &amp; Smartcard Integration</small>
  </div>
</div>
