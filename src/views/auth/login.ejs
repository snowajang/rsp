<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title><%= title || 'Login' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      min-height: 100vh;
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #4a90e2, #9013fe);
      font-family: 'Segoe UI', sans-serif;
    }

    .login-card {
      width: 100%;
      max-width: 420px;
      animation: fadeIn 0.6s ease;
    }

    @keyframes fadeIn {
      from {opacity: 0; transform: translateY(15px);}
      to   {opacity: 1; transform: translateY(0);}
    }

    .card {
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .card-header {
      background: #fff;
      padding: 25px 20px;
      border-bottom: none;
    }

    .brand-icon {
      width: 60px;
      height: 60px;
      background: #4a90e2;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 32px;
      margin: 0 auto 10px;
      box-shadow: 0 4px 12px rgba(74,144,226,0.4);
    }

    .form-control {
      border-radius: 10px;
      padding: 10px 14px;
      border: 1px solid #ced4da;
      transition: 0.2s;
    }

    .form-control:focus {
      border-color: #4a90e2;
      box-shadow: 0 0 0 3px rgba(74,144,226,0.25);
    }

    .btn-primary {
      background: #4a90e2;
      border: none;
      border-radius: 10px;
      padding: 10px;
      font-weight: 600;
      letter-spacing: 0.3px;
      transition: 0.25s;
    }

    .btn-primary:hover {
      background: #3f7fcb;
      box-shadow: 0 6px 15px rgba(0,0,0,0.15);
      transform: translateY(-1px);
    }

    .card-footer {
      background-color: #f8f9fa;
      font-size: 13px;
      padding: 12px;
    }
    
    .tha-id-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(15, 118, 110, 0.25);
      color: #99f6e4;
      font-size: 0.75rem;
      margin-bottom: 10px;
    }

    .tha-id-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 0 5px rgba(34, 197, 94, 0.2);
    }

    .btn-thaid {
      background: linear-gradient(135deg, #0ea5e9, #22c55e);
      border: none;
      border-radius: 12px;
      padding: 11px 18px;
      font-weight: 600;
      letter-spacing: 0.2px;
      font-size: 0.95rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      color: #0b1120;
      box-shadow: 0 10px 25px rgba(34, 197, 94, 0.45);
      transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
    }

    .btn-thaid:hover {
      transform: translateY(-1px);
      filter: brightness(1.02);
      box-shadow: 0 14px 32px rgba(34, 197, 94, 0.60);
    }

    .btn-thaid:active {
      transform: translateY(0px) scale(0.99);
      box-shadow: 0 8px 18px rgba(15, 23, 42, 0.85);
    }

    .btn-thaid-icon {
      font-size: 1.15rem;
    }

  </style>
</head>

<body>
  <div class="login-card">
    <div class="card border-0">

      <div class="card-header text-center bg-white">
        <div class="brand-badge">
          <img src="/images/exat-logo.svg" alt="EXAT Logo" width="254">
        </div>
        <div class="brand-icon">
          🔒
        </div>
        <h5 class="fw-bold mb-0">EXAT Admin Login</h5>
        <p class="text-muted small mb-0 mt-1">เข้าสู่ระบบเพื่อจัดการข้อมูล</p>
      </div>

      <div class="card-body">
        <% if (error) { %>
          <div class="alert alert-danger py-2 mb-3"><%= error %></div>
        <% } %>

        <form method="post" action="/auth/login">
          <div class="mb-3">
            <label class="form-label">รหัสผู้ใช้งาน</label>
            <input type="username" name="username" class="form-control" required autofocus>
          </div>

          <div class="mb-3">
            <label class="form-label">รหัสผ่าน</label>
            <input type="password" name="password" class="form-control" required>
          </div>

          <button type="submit" class="btn btn-primary w-100">เข้าสู่ระบบ</button>
        </form>
        <hr />
        <form method="post" action="/auth/thaidlogin" class="mt-3">
          <button type="submit" class="btn-thaid mb-3">
            <span class="btn-thaid-icon">🔐</span>
            <span>เข้าระบบด้วย ThaID</span>
          </button>
          <p class="helper-text">
            เมื่อกดปุ่มระบบจะพาไปยังหน้าจอยืนยันตัวตนของแอป ThaID เพื่อยืนยันตัวตนของคุณ
          </p>
        </form>
      </div>

      <div class="card-footer text-center text-muted">
        © <%= new Date().getFullYear() %> NMS Networks. All rights reserved.
      </div>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
