generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  pid           BigInt   @id @default(0)
  name          String
  email         String   @unique
  username      String   @unique
  passwordHash  String
  role          String   @default("user")
  createdAt     DateTime @default(now())
  lastLogin     DateTime @default(now())
  token         String   @db.VarChar(255) @default("")
}

model thaid {
  istate        String   @db.VarChar(200)
  returnurl     String   @db.Text @default("")
  scope         String   @db.Text @default("")
  userpid       BigInt   @default(0)
  termdate      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@id([istate, termdate])
}

model applog {
  id            BigInt   @id @default(autoincrement())
  userid        BigInt?
  endpoint      String   @db.Text
  method        String   @db.Text
  ipaddress     String   @db.Text
  reqHeader     Json?
  reqBody       Json?
  resStatus     Int?
  resBody       Json?
  details       String   @db.Text
  createdAt     DateTime @default(now())
  status        Int      @default(0)
}

model userlog {
  id            BigInt   @id @default(autoincrement())
  userid        BigInt
  action        String   @db.Text
  details       String   @db.Text
  createdAt     DateTime @default(now())
}